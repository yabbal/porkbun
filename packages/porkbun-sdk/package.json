{
	"name": "porkbun-sdk",
	"version": "1.0.1",
	"description": "TypeScript SDK for the Porkbun API — manage domains, DNS, SSL and more",
	"type": "module",
	"license": "MIT",
	"author": "yabbal",
	"repository": {
		"type": "git",
		"url": "https://github.com/yabbal/porkbun.git",
		"directory": "packages/porkbun-sdk"
	},
	"homepage": "https://github.com/yabbal/porkbun",
	"bugs": {
		"url": "https://github.com/yabbal/porkbun/issues"
	},
	"keywords": [
		"porkbun",
		"sdk",
		"api",
		"domain",
		"dns",
		"ssl",
		"registrar",
		"typescript"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"test": "vitest run"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.6",
		"@vitest/coverage-v8": "^4.1.0",
		"tsup": "^8.5.0",
		"typescript": "^5.8.3",
		"vitest": "^4.1.0"
	}
}
