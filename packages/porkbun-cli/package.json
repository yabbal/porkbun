{
	"name": "porkbun-cli",
	"version": "1.0.1",
	"description": "CLI for Porkbun — manage domains, DNS, SSL and more from the terminal",
	"type": "module",
	"license": "MIT",
	"author": "yabbal",
	"repository": {
		"type": "git",
		"url": "https://github.com/yabbal/porkbun.git",
		"directory": "packages/porkbun-cli"
	},
	"homepage": "https://github.com/yabbal/porkbun",
	"bugs": {
		"url": "https://github.com/yabbal/porkbun/issues"
	},
	"keywords": [
		"porkbun",
		"cli",
		"domain",
		"dns",
		"ssl",
		"registrar",
		"nameserver",
		"dnssec"
	],
	"bin": {
		"porkbun": "./dist/cli.js"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"format": "biome format --write src/",
		"test": "vitest run"
	},
	"dependencies": {
		"citty": "^0.2.1",
		"cli-table3": "^0.6.5",
		"consola": "^3.4.2",
		"dotenv": "^17.3.1",
		"porkbun-sdk": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.11",
		"@types/node": "^25.6.0",
		"@vitest/coverage-v8": "^4.1.4",
		"tsup": "^8.5.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	}
}
